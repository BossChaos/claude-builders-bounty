{
  "name": "Weekly GitHub Dev Summary",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "dayOfWeek",
              "hours": "17",
              "minutes": "0",
              "dayOfWeek": "5"
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.github.com/repos/{{ $env.GITHUB_REPO_OWNER }}/{{ $env.GITHUB_REPO_NAME }}/commits",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "githubApi",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "since",
              "value": "={{ $now.minus({ days: 7 }).toISOString() }}"
            },
            {
              "name": "per_page",
              "value": "100"
            }
          ]
        }
      },
      "id": "github-commits",
      "name": "Fetch Commits",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.github.com/repos/{{ $env.GITHUB_REPO_OWNER }}/{{ $env.GITHUB_REPO_NAME }}/issues",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "githubApi",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "state",
              "value": "closed"
            },
            {
              "name": "since",
              "value": "={{ $now.minus({ days: 7 }).toISOString() }}"
            },
            {
              "name": "per_page",
              "value": "100"
            }
          ]
        }
      },
      "id": "github-issues",
      "name": "Fetch Closed Issues",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 500]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.github.com/repos/{{ $env.GITHUB_REPO_OWNER }}/{{ $env.GITHUB_REPO_NAME }}/pulls",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "githubApi",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "state",
              "value": "closed"
            },
            {
              "name": "since",
              "value": "={{ $now.minus({ days: 7 }).toISOString() }}"
            },
            {
              "name": "per_page",
              "value": "100"
            }
          ]
        }
      },
      "id": "github-prs",
      "name": "Fetch Merged PRs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 700]
    },
    {
      "parameters": {
        "mode": "combine",
        "combinationMode": "mergeByPosition",
        "options": {
          "fuzzyCompare": false,
          "includeUnpaired": true
        }
      },
      "id": "merge-data",
      "name": "Merge GitHub Data",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [440, 500]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "{{ $env.CLAUDE_MODEL || 'claude-sonnet-4-20250514' }}"
            },
            {
              "name": "max_tokens",
              "value": "2048"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"user\", \"content\": \"Generate a weekly developer summary based on this GitHub activity:\\n\\nCommits ({{ $json.commits?.length || 0 }}):\\n{{ $json.commits?.map(c => '- ' + c.commit.message + ' by ' + c.commit.author?.name).join('\\n') || 'No commits'}}\\n\\nClosed Issues ({{ $json.issues?.length || 0 }}):\\n{{ $json.issues?.map(i => '- #' + i.number + ': ' + i.title + ' by ' + i.user?.login).join('\\n') || 'No issues'}}\\n\\nMerged PRs ({{ $json.prs?.length || 0 }}):\\n{{ $json.prs?.map(p => '- #' + p.number + ': ' + p.title + ' by ' + p.user?.login).join('\\n') || 'No PRs'}}\\n\\nFormat as a friendly, concise summary with emoji. Highlight key achievements.\"}]"}
            }
          ]
        },
        "options": {}
      },
      "id": "claude-summary",
      "name": "Generate Summary with Claude",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [660, 500]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $env.DISCORD_WEBHOOK_URL }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"content\": \"📊 **Weekly Dev Summary**\\n\\n{{ $json.content[0].text }}\"\n}",
        "options": {}
      },
      "id": "discord-webhook",
      "name": "Send to Discord",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 500]
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [
          {
            "node": "Fetch Commits",
            "type": "main",
            "index": 0
          },
          {
            "node": "Fetch Closed Issues",
            "type": "main",
            "index": 0
          },
          {
            "node": "Fetch Merged PRs",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Commits": {
      "main": [
        [
          {
            "node": "Merge GitHub Data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Closed Issues": {
      "main": [
        [
          {
            "node": "Merge GitHub Data",
            "type": "main",
            "index": 1
          }
        ]
      ]
    },
    "Fetch Merged PRs": {
      "main": [
        [
          {
            "node": "Merge GitHub Data",
            "type": "main",
            "index": 2
          }
        ]
      ]
    },
    "Merge GitHub Data": {
      "main": [
        [
          {
            "node": "Generate Summary with Claude",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Generate Summary with Claude": {
      "main": [
        [
          {
            "node": "Send to Discord",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "tags": [],
  "triggerCount": 1,
  "updatedAt": "2026-04-21T09:00:00.000Z",
  "versionId": "1"
}
